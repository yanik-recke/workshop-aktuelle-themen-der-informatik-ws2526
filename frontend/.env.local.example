# MongoDB Connection String
# Get this from your MongoDB Atlas dashboard or use local MongoDB
# Example for local: mongodb://localhost:27017
# Example for Docker: mongodb://admin:password@mongodb:27017
MONGODB_URI=mongodb://admin:password@localhost:27017

# RAG API URL
# For local development with Docker: http://localhost:8000
NEXT_PUBLIC_RAG_API_URL=http://localhost:8000
