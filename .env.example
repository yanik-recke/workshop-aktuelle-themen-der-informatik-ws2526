# OpenAI-Compatible API Configuration
# For Ollama running on host machine (recommended for better GPU performance)
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# For Ollama in Docker container (uncomment and enable ollama service in docker-compose.yml)
# OPENAI_API_KEY=dummy
# OPENAI_BASE_URL=http://ollama:11434/v1

# For LM Studio (if running outside Docker)
# OPENAI_API_KEY=not-needed
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1

# For actual OpenAI API
# OPENAI_API_KEY=sk-your-actual-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Qdrant Configuration (automatically set in docker-compose)
QDRANT_URL=http://qdrant:6333
